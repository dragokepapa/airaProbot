{
  "name": "Aira Pro Bot",
  "description": "Telegram userbot / bot deploy",
  "logo": "https://telegra.ph/file/3b6e0a2c5b9e9f1c9c1d2.jpg",
  "keywords": ["telegram", "bot", "userbot", "pyrogram"],
  "repository": "https://github.com/dragokepapa/airaProbot",
  "website": "https://github.com/dragokepapa/airaProbot",
  "success_url": "/",
  "stack": "heroku-22",

  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ],

  "env": {
    "API_ID": {
      "description": "Get from my.telegram.org",
      "required": true
    },
    "API_HASH": {
      "description": "Get from my.telegram.org",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "Get from @BotFather",
      "required": true
    },
    "SESSION_STRING": {
      "description": "Pyrogram session string (if needed)",
      "required": false
    }
  }
}